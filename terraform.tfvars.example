# --- Provider ---
proxmox_api_url = "https://192.168.3.168:8006/api2/json"

# proxmox_api_token=<ProxMox TokenID >=<Secret>

proxmox_insecure = false
environment      = "dev"

# --- VM ---
proxmox_node   = “linux-box"
template_vm_id = 9000
vm_id          = 101
vm_name        = "ubuntu24-dev"

datastore_id = "local-lvm"

vm_cores     = 2
vm_memory_mb = 2048
vm_disk_gb   = 10

bridge        = "vmbr0"
ipv4_address  = “192.168.3.111/24"
ipv4_gateway  = "192.168.3.1"

# ssh_public_key = "ssh-rsa AAAA..."
vm_username = "ubuntu"
